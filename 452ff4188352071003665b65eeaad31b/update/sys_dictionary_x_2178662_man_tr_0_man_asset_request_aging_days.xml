        <calculation><![CDATA[(function calculatedFieldValue(current) {

	//Created by : Sandesh Bhale, Created On : 22-07-2026
	//Purpose : To Calculate the Aging Days

    var now = new GlideDateTime();
	var createdDate = new GlideDateTime(current.sys_created_on);
    var ageInDays = Math.floor(
        (now.getNumericValue() - createdDate.getNumericValue()) /
        86400000
    );
    return ageInDays; // return the calculated value

})(current);]]></calculation>
